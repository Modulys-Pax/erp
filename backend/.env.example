# ==================================
# SPOLIER ERP - Backend Configuration
# ==================================

# PostgreSQL Database
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/spolier_db?schema=public"

# JWT Configuration
# IMPORTANT: In production, JWT_SECRET is required, min 32 chars (app will not start otherwise)
JWT_SECRET="your-very-secure-secret-key-minimum-32-characters"
# Access token TTL (JWT_EXPIRATION também é aceito como alias)
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRATION="30d"

# Server
PORT=3001
NODE_ENV=development

# HTTP JSON body limit (uploads use multipart — keep this modest to reduce DoS risk)
JSON_BODY_LIMIT=2mb

# Rate limit: max requests per IP per minute (default 180). Auth routes have stricter limits.
THROTTLE_GLOBAL_LIMIT=180

# Swagger: disabled when NODE_ENV=production unless SWAGGER_ENABLED=true
# SWAGGER_ENABLED=true

# File Upload (optional)
# Directory where uploads will be saved
UPLOAD_DIR=uploads

# Upload size limit in bytes (50MB)
MAX_FILE_SIZE=52428800

# FFmpeg (optional - for video compression)
# If not configured, videos will be saved without compression
# FFMPEG_PATH=/usr/bin/ffmpeg
